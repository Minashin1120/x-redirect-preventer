{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "version": "1.0.3",
  "description": "__MSG_extension_description__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "webRequest",
    "webNavigation",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting"
  ],
  "host_permissions": [
    "*://api.x.com/*",
    "*://x.com/*",
    "*://twitter.com/*",
    "*://api.twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content_isolated.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content_main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
